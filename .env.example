# ── Local development (Ollama) ──────────────────────────────────────────────
# Used when AZURE_OPENAI_ENDPOINT is not set.

# Model name (must be pulled in Ollama)
OLLAMA_MODEL=llama3.2

# Ollama server URL
OLLAMA_BASE_URL=http://localhost:11434

# ── Azure deployment (Azure OpenAI) ─────────────────────────────────────────
# When AZURE_OPENAI_ENDPOINT is set, Ollama is ignored and Azure OpenAI is used.

# AZURE_OPENAI_ENDPOINT=<endpoint_url>
# AZURE_OPENAI_API_KEY=<secret>
# AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
# AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── Shared ───────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:5173

# ── Keycloak / OIDC (BFF auth) ───────────────────────────────────────────────
# Defaults below match the docker-compose setup (backend reaches Keycloak at
# http://keycloak:8080 on the shared network). For running uvicorn directly on
# the host instead, use http://localhost:8081 and the :5173 redirect URI.
OIDC_DISCOVERY_URL=http://keycloak:8080/realms/findocs/.well-known/openid-configuration
OIDC_CLIENT_ID=findocs-bff
OIDC_CLIENT_SECRET=dev-secret-change-me
OIDC_REDIRECT_URI=http://localhost:8080/api/auth/callback
OIDC_POST_LOGIN_REDIRECT=http://localhost:8080/
OIDC_POST_LOGOUT_REDIRECT=http://localhost:8080/
# Use `openssl rand -hex 32` for a real secret. Set SESSION_HTTPS_ONLY=true in prod.
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_HTTPS_ONLY=false
