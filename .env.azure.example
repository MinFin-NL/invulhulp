# ── Pilot backend (BFF) on Azure Container Apps ──────────────────────────────
# Copy per pilot and set the values for THAT pilot's realm + domain. On Container
# Apps, set OIDC_CLIENT_SECRET and SESSION_SECRET as secrets (Key Vault refs),
# not plaintext here. auth.py reads exactly these variable names.

# ── LLM (Azure OpenAI in production) ─────────────────────────────────────────
AZURE_OPENAI_ENDPOINT=https://<your-aoai>.openai.azure.com/
# AZURE_OPENAI_API_KEY=<secretref>
AZURE_OPENAI_DEPLOYMENT=gpt-5.3-chat
AZURE_OPENAI_API_VERSION=2025-04-01-preview

# ── CORS — the pilot's own frontend origin ───────────────────────────────────
CORS_ORIGINS=https://app.pilot-a.nl

# ── Keycloak / OIDC ──────────────────────────────────────────────────────────
# Central Keycloak, this pilot's realm. Public https — same URL back-channel and
# front-channel, so no backchannel-dynamic hack is needed in Azure.
OIDC_DISCOVERY_URL=https://keycloak.<your-env>.azurecontainerapps.io/realms/pilot-a/.well-known/openid-configuration
OIDC_CLIENT_ID=pilot-a-bff
OIDC_CLIENT_SECRET=<secretref:pilot-a-oidc-secret>     # from Key Vault, per pilot
OIDC_REDIRECT_URI=https://app.pilot-a.nl/api/auth/callback
OIDC_POST_LOGIN_REDIRECT=https://app.pilot-a.nl/
OIDC_POST_LOGOUT_REDIRECT=https://app.pilot-a.nl/

# ── Session cookie ───────────────────────────────────────────────────────────
SESSION_SECRET=<secretref:pilot-a-session-secret>      # openssl rand -hex 32, per pilot
SESSION_HTTPS_ONLY=true
